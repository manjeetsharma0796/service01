# --- Required ---

# Solana base58 pubkey that will RECEIVE USDC payments.
# This must be an account you control. The mock advertises the same recipient
# for both mainnet and devnet methods (you can split if you prefer).
#
# Generate a fresh keypair: `solana-keygen new --no-bip39-passphrase --outfile mock-wallet.json`
# Then: `solana-keygen pubkey mock-wallet.json`
SOLANA_RECIPIENT=REPLACE_WITH_BASE58_PUBKEY

# --- Optional ---

# 32-byte base64 secret used by mppx to sign challenge IDs (HMAC).
# If unset, mppx generates a random one at startup — fine for ephemeral demos,
# but every restart invalidates outstanding challenges. Set it for stable URLs.
#
# Generate: `openssl rand -base64 32`
MPP_SECRET_KEY=

# Bind port — Render sets PORT automatically; 3000 is sane for local
PORT=3000

# Optional fee-payer pubkey (gas sponsorship). If set, the server advertises
# extras.feePayer in the Solana method details so clients don't need SOL.
# Leave blank if you want clients to cover gas themselves.
SOLANA_FEE_PAYER=

# Network to advertise. mppx 0.6.x requires a unique (name, intent) per Mppx
# instance, so each server advertises ONE Solana network. Run two services
# (different ports) if you need both.
#   ADVERTISE=mainnet-beta     (default; "mainnet" is also accepted)
#   ADVERTISE=devnet           (for Klink CI fixture mode)
#   ADVERTISE=localnet
ADVERTISE=mainnet-beta
